{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "fantasy-labama-admin",
  "compatibility_date": "2026-05-12",
  "pages_build_output_dir": "dist",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
